{
  "name": "quest-react-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run lint && vite build",
    "lint": "eslint .",
    "lint:error": "eslint . --quiet",
    "preview": "vite preview",
    "deploy:worker": "npx wrangler deploy --config edge-coder-worker/wrangler.toml",
    "deploy:pages": "npx wrangler pages deploy ./dist --project-name axim-coding-lab-dashboard --branch main"
  },
  "dependencies": {
    "@questlabs/react-sdk": "^2.2.92",
    "@supabase/supabase-js": "^2.110.2",
    "date-fns": "4.1.0",
    "dotenv": "^17.4.2",
    "echarts": "^5.5.0",
    "echarts-for-react": "^3.0.2",
    "framer-motion": "^11.0.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.4.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260714.1",
    "@eslint/js": "^9.39.5",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^7.0.2",
    "vite": "^5.4.2",
    "wrangler": "^4.111.0"
  }
